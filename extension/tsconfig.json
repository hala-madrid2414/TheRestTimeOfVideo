{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "../dist",
    "noEmit": false
  },
  "include": ["./**/*.ts", "./**/*.d.ts"]
}
