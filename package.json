{
  "name": "the-rest-time-of-video",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "dev": "vite --config vite.config.ts",
    "build:extension": "tsc -p extension/tsconfig.json",
    "build": "npm run clean && vite build --config vite.config.ts && npm run build:extension && node scripts/copy-extension-assets.mjs",
    "preview": "vite preview --config vite.config.ts",
    "typecheck": "tsc -p app/tsconfig.json --noEmit && tsc -p extension/tsconfig.json --noEmit",
    "dist:check": "node scripts/check-dist.mjs",
    "verify": "npm run typecheck && npm run build && npm run dist:check"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
